{
  "appId": "com.abuibrahim.qrstudio",
  "productName": "QR Studio",
  "copyright": "Copyright © 2026 AbuiBrahim",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "portable", "arch": ["x64"] }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "QR Studio",
    "artifactName": "QR-Studio-Setup-${version}.${ext}"
  },
  "portable": {
    "artifactName": "QR-Studio-Portable-${version}.${ext}"
  }
}
